#Авторизация с повторными попытками
def get_gigachat_token(client_id: str, client_secret: str, retries=3) -> str:
    url = "https://ngw.devices.sberbank.ru:9443/api/v2/oauth"
    credentials = f"{client_id}:{client_secret}"
    encoded_credentials = base64.b64encode(credentials.encode()).decode()

    headers = {
        "Content-Type": "application/x-www-form-urlencoded",
        "RqUID": "12345678-1234-1234-1234-123456789012",
        "Authorization": f"Basic {encoded_credentials}"
    }
    data = {"scope": "GIGACHAT_API_PERS"}

    for attempt in range(retries):
        try:
            response = requests.post(url, headers=headers, data=data, verify=False, timeout=30)
            response.raise_for_status()
            return response.json()["access_token"]
        except Exception as e:
            print(f"Ошибка получения токена (попытка {attempt+1}/{retries}): {e}") # проверка, вынос ошибки
            time.sleep(2 ** attempt)
    raise Exception("Не удалось получить токен GigaChat")

